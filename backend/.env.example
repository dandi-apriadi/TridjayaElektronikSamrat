# Local development may use localhost without TLS.
# Production remote DB must use verified TLS, for example:
# mysql://tridjaya:your_mysql_password_here@db.example.com:3306/tridjaya?ssl-mode=VERIFY_IDENTITY&ssl-ca=/etc/ssl/mysql/ca.pem
DATABASE_URL=mysql://tridjaya:your_mysql_password_here@localhost:3306/tridjaya
# KVM 2 has 2 vCPU. Keep DB concurrency bounded; raise only after load testing.
MYSQL_MAX_CONNECTIONS=25
REQUEST_TIMEOUT_SECS=30
PUBLIC_CATALOG_LIMIT=50
PUBLIC_CATALOG_MAX_LIMIT=100
PUBLIC_READ_MAX_PER_MINUTE=120
TELEMETRY_ANALYTICS_WINDOW_DAYS=30
WA_ENQUEUE_BATCH_SIZE=1000
APP_ENV=development
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
RUST_LOG=info

# URL dasar frontend, dipakai untuk membentuk link verifikasi email & reset
# password yang dikirim via email.
FRONTEND_URL=http://localhost:5173

# Pasang Secure flag pada cookie refresh-token. WAJIB true di produksi (HTTPS).
COOKIE_SECURE=false

# 32 bytes / 64 hex chars. Required when APP_ENV=production.
# Used for Meta Pixel tokens and encrypted PII fields.
# Generate with: openssl rand -hex 32
PIXEL_ENCRYPTION_KEY=

# Set ke `true` HANYA untuk testing lokal jika Anda sengaja ingin tetap pakai
# fallback key all-zero (mis. unit test). Di produksi NEVER set ini.
ALLOW_INSECURE_PIXEL_KEY=false

# Emergency-only override for production remote MySQL without verified TLS.
# Keep false. Prefer DATABASE_URL with ssl-mode=VERIFY_CA or VERIFY_IDENTITY.
ALLOW_INSECURE_DATABASE_TLS=false

# Konfigurasi SMTP. Jangan commit nilai sebenarnya. Bila SMTP_EMAIL atau
# SMTP_PASSWORD kosong, modul mailer akan dinonaktifkan dan email tidak
# akan dikirim (operasi terkait akan dicatat di log).
SMTP_EMAIL=
SMTP_PASSWORD=
SMTP_SERVER=smtp.gmail.com

# Wajib di-set ke `true` jika aplikasi berada di belakang reverse proxy
# (misalnya Nginx, Cloudflare) agar IP rate limit menggunakan header X-Forwarded-For
# alih-alih IP proxy lokal. Jika false, IP rate-limit otomatis memakai TCP
# peer address yang di-inject middleware `inject_peer_ip` (Quick Win #4).
TRUST_PROXY_HEADERS=false

# Set ke `true` untuk mengaktifkan CSP ketat (tanpa 'unsafe-inline'). Roll out
# setelah memastikan production bundle Vite tidak emit inline scripts/styles.
STRICT_CSP=false

# hCaptcha secret untuk verifikasi captcha pada endpoint agent registration
# dan submission publik. Jika kosong, verifikasi captcha dinonaktifkan (form
# tetap menerima request tanpa token captcha). Ambil dari dashboard hCaptcha.
HCAPTCHA_SECRET=
