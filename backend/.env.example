DATABASE_URL=mysql://tridjaya:your_mysql_password_here@localhost:3306/tridjaya
MYSQL_MAX_CONNECTIONS=50
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
RUST_LOG=info

# URL dasar frontend, dipakai untuk membentuk link verifikasi email & reset
# password yang dikirim via email.
FRONTEND_URL=http://localhost:5173

# Pasang Secure flag pada cookie refresh-token. WAJIB true di produksi (HTTPS).
COOKIE_SECURE=false

# Konfigurasi SMTP. Jangan commit nilai sebenarnya. Bila SMTP_EMAIL atau
# SMTP_PASSWORD kosong, modul mailer akan dinonaktifkan dan email tidak
# akan dikirim (operasi terkait akan dicatat di log).
SMTP_EMAIL=
SMTP_PASSWORD=
SMTP_SERVER=smtp.gmail.com

# Wajib di-set ke `true` jika aplikasi berada di belakang reverse proxy
# (misalnya Nginx, Cloudflare) agar IP rate limit menggunakan header X-Forwarded-For
# alih-alih IP proxy lokal.
TRUST_PROXY_HEADERS=false
