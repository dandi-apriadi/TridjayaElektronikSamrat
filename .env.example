# Root env is only used by helper scripts. Backend runtime reads backend/.env.

APP_ENV=production
ALLOWED_ORIGINS=https://tridjaya.com,https://www.tridjaya.com
COOKIE_SECURE=true
TRUST_PROXY_HEADERS=true

# MySQL database used by native deployment helpers.
DATABASE_URL=mysql://tridjaya:your_mysql_password_here@127.0.0.1:3306/tridjaya

# Redis used by the native backend service.
REDIS_URL=redis://127.0.0.1:6379
REDIS_PASSWORD=

# 32 bytes / 64 hex chars. Generate with:
# openssl rand -hex 32
PIXEL_ENCRYPTION_KEY=replace_with_64_hex_chars

# Browser-visible URLs.
VITE_API_BASE_URL=https://tridjaya.com
VITE_FRONTEND_URL=https://tridjaya.com
