# Docker Compose environment variables
# Copy this file to .env and fill in the values

# Redis password (required)
REDIS_PASSWORD=your_redis_password_here

# Backend production runtime
APP_ENV=production
ALLOWED_ORIGINS=https://tridjayaelektronik.com,https://www.tridjayaelektronik.com
COOKIE_SECURE=true
TRUST_PROXY_HEADERS=true

# 32 bytes / 64 hex chars. Generate with:
# openssl rand -hex 32
PIXEL_ENCRYPTION_KEY=replace_with_64_hex_chars

# Backend API URL (as seen from the browser)
VITE_API_BASE_URL=https://api.tridjayaelektronik.com

# Public frontend URL — used for generating referral links
# Must match the domain customers will access
VITE_FRONTEND_URL=https://tridjayaelektronik.com
