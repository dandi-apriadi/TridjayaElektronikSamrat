# Root env is only used by helper scripts. Backend runtime reads backend/.env.

APP_ENV=production
ALLOWED_ORIGINS=https://tridjaya.com,https://www.tridjaya.com
COOKIE_SECURE=true
TRUST_PROXY_HEADERS=true

# MySQL database used by native deployment helpers.
# For remote production DBs, use verified TLS:
# mysql://tridjaya:your_mysql_password_here@db.example.com:3306/tridjaya?ssl-mode=VERIFY_IDENTITY&ssl-ca=/etc/ssl/mysql/ca.pem
DATABASE_URL=mysql://tridjaya:your_mysql_password_here@127.0.0.1:3306/tridjaya
ALLOW_INSECURE_DATABASE_TLS=false
MYSQL_MAX_CONNECTIONS=25
REQUEST_TIMEOUT_SECS=30
PUBLIC_CATALOG_LIMIT=50
PUBLIC_CATALOG_MAX_LIMIT=100
PUBLIC_READ_MAX_PER_MINUTE=120
TELEMETRY_ANALYTICS_WINDOW_DAYS=30
WA_ENQUEUE_BATCH_SIZE=1000

# Redis used by the native backend service.
REDIS_URL=redis://127.0.0.1:6379
REDIS_PASSWORD=

# 32 bytes / 64 hex chars. Generate with:
# openssl rand -hex 32
PIXEL_ENCRYPTION_KEY=replace_with_64_hex_chars

# Browser-visible URLs.
VITE_API_BASE_URL=https://tridjaya.com
VITE_FRONTEND_URL=https://tridjaya.com
VITE_ALLOWED_API_ORIGINS=https://tridjaya.com
VITE_HCAPTCHA_SITE_KEY=
